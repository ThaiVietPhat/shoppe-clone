<?xml version="1.0" encoding="UTF-8"?>
<!--
    Declares Spring Modulith's internal JPA entity so Hibernate can resolve
    DefaultJpaEventPublication in JPQL queries run by JpaEventPublicationRepository.

    Context: Spring Boot 4 removed @EntityScan from the autoconfigure domain package.
    Spring Modulith 2.0.0's JpaEventPublicationAutoConfiguration relies on @EntityScan
    to register its entity — this no longer works in Spring Boot 4.

    PersistenceUnitPostProcessor is context-order-dependent and unreliable across
    Spring test contexts (e.g. full app vs ES-disabled context).

    META-INF/orm.xml is processed directly by the JPA provider (Hibernate) during
    persistence unit initialization, before any Spring auto-configuration ordering
    can interfere. This is the most reliable fix.
-->
<entity-mappings
        xmlns="https://jakarta.ee/xml/ns/persistence/orm"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence/orm
            https://jakarta.ee/xml/ns/persistence/orm/orm_3_2.xsd"
        version="3.2">
    <entity class="org.springframework.modulith.events.jpa.updating.DefaultJpaEventPublication"/>
</entity-mappings>
